    <append xpath="/entitygroups">
      <entitygroup name="MyModForestZombies">
        <entity name="zombieArlene" prob="0.4"/>
        <entity name="zombieMoe"    prob="0.3"/>
        <entity name="zombieSteve"  prob="0.3"/>
      </entitygroup>
    </append>

  Add an entity to an existing group:
    <append xpath="/entitygroups/entitygroup[@name='ZombiesForestDay']">
      <entity name="zombieMutated" prob="0.1"/>
