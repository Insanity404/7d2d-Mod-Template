.vs/*
!.vs/launch.vs.json
*.suo
*.user
*.userosscache
*.sln.docstates

# .NET build output
/bin/
/obj/

# VS Code - keep tasks/launch/extensions committed, ignore machine-specific settings
.vscode/settings.json
.vscode/*.code-workspace

# Log files
*.log
*.bak

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store
**/.DS_Store
